inline constexpr intmax_t __ratio_max = numeric_limits<intmax_t>::max();
inline constexpr intmax_t __ratio_min = -__ratio_max;
inline constexpr intmax_t __ratio_nan = numeric_limits<intmax_t>::min();

// __static_gcd

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __static_gcd(intmax_t __x, intmax_t __y) noexcept
{
  if (__y == 0)
  {
    return (__x == 0) ? 1 : __x;
  }
  else
  {
    return _CUDA_VSTD::__static_gcd(__y, __x % __y);
  }
}

// __static_lcm

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __static_lcm(intmax_t __x, intmax_t __y) noexcept
{
  return __x / _CUDA_VSTD::__static_gcd(__x, __y) * __y;
}

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __ratio_sign(intmax_t __x) noexcept
{
  return __x == 0 ? 0 : (__x < 0 ? -1 : 1);
}

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __ll_add(intmax_t __lhs, intmax_t __rhs) noexcept
{
  const auto __rhs_sign = _CUDA_VSTD::__ratio_sign(__rhs);
  if (__rhs_sign == 1)
  {
    _CCCL_ASSERT(__lhs <= __ratio_max - __rhs, "overflow in __ll_add");
  }
  else if (__rhs_sign == -1)
  {
    _CCCL_ASSERT(__ratio_min - __rhs <= __lhs, "overflow in __ll_add");
  }

  return __lhs + __rhs;
}

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __ll_sub(intmax_t __lhs, intmax_t __rhs) noexcept
{
  const auto __rhs_sign = _CUDA_VSTD::__ratio_sign(__rhs);
  if (__rhs_sign == 1)
  {
    _CCCL_ASSERT(__ratio_min + __rhs <= __lhs, "overflow in __ll_sub");
  }
  else if (__rhs_sign == -1)
  {
    _CCCL_ASSERT(__lhs <= __ratio_max + __rhs, "overflow in __ll_sub");
  }

  return __lhs - __rhs;
}

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __ll_mul(intmax_t __lhs, intmax_t __rhs) noexcept
{
  if (__lhs == 0 || __rhs == 0)
  {
    return 0;
  }

  _CCCL_ASSERT(__lhs != __ratio_nan && __rhs != __ratio_nan, "overflow in __ll_mul");

  const auto __lhs_abs = _CUDA_VSTD::abs(__lhs);
  const auto __rhs_abs = _CUDA_VSTD::abs(__rhs);

  _CCCL_ASSERT(__lhs_abs <= __ratio_max / __rhs_abs, "overflow in __ll_mul");

  return __lhs * __rhs;
}

template <intmax_t _Num, intmax_t _Den = 1>
class _CCCL_TYPE_VISIBILITY_DEFAULT ratio
{
  static_assert(_CUDA_VSTD::abs(_Num) >= 0, "ratio numerator is out of range");
  static_assert(_Den != 0, "ratio divide by 0");
  static_assert(_CUDA_VSTD::abs(_Den) > 0, "ratio denominator is out of range");
  static constexpr intmax_t __na  = _CUDA_VSTD::abs(_Num);
  static constexpr intmax_t __da  = _CUDA_VSTD::abs(_Den);
  static constexpr intmax_t __s   = _CUDA_VSTD::__ratio_sign(_Num) * _CUDA_VSTD::__ratio_sign(_Den);
  static constexpr intmax_t __gcd = _CUDA_VSTD::__static_gcd(__na, __da);

public:
  static constexpr intmax_t num = __s * __na / __gcd;
  static constexpr intmax_t den = __da / __gcd;

  using type = ratio<num, den>;
};

template <class _Tp>
struct __is_ratio : false_type
{};
template <intmax_t _Num, intmax_t _Den>
struct __is_ratio<ratio<_Num, _Den>> : true_type
{};

using atto  = ratio<1LL, 1000000000000000000LL>;
using femto = ratio<1LL, 1000000000000000LL>;
using pico  = ratio<1LL, 1000000000000LL>;
using nano  = ratio<1LL, 1000000000LL>;
using micro = ratio<1LL, 1000000LL>;
using milli = ratio<1LL, 1000LL>;
using centi = ratio<1LL, 100LL>;
using deci  = ratio<1LL, 10LL>;
using deca  = ratio<10LL, 1LL>;
using hecto = ratio<100LL, 1LL>;
using kilo  = ratio<1000LL, 1LL>;
using mega  = ratio<1000000LL, 1LL>;
using giga  = ratio<1000000000LL, 1LL>;
using tera  = ratio<1000000000000LL, 1LL>;
using peta  = ratio<1000000000000000LL, 1LL>;
using exa   = ratio<1000000000000000000LL, 1LL>;

struct __ratio_vals
{};

[[nodiscard]] _LIBCUDACXX_HIDE_FROM_ABI constexpr intmax_t __ll_mul(intmax_t __lhs, intmax_t __rhs) noexcept
{
  if (__lhs == 0 || __rhs == 0)
  {
    return 0;
  }

  _CCCL_ASSERT(__lhs != __ratio_nan && __rhs != __ratio_nan, "overflow in __ll_mul");

  const auto __lhs_abs = _CUDA_VSTD::abs(__lhs);
  const auto __rhs_abs = _CUDA_VSTD::abs(__rhs);

  _CCCL_ASSERT(__lhs_abs <= __ratio_max / __rhs_abs, "overflow in __ll_mul");

  return __lhs * __rhs;
}

template <class _R1, class _R2>
struct __ratio_multiply
{
  // private:
  static const intmax_t __gcd_n1_d2 = _CUDA_VSTD::__static_gcd(_R1::num, _R2::den);
  static const intmax_t __gcd_d1_n2 = _CUDA_VSTD::__static_gcd(_R1::den, _R2::num);

public:
  using type = typename ratio<_CUDA_VSTD::__ll_mul(_R1::num / __gcd_n1_d2, _R2::num / __gcd_d1_n2),
                              _CUDA_VSTD::__ll_mul(_R2::den / __gcd_n1_d2, _R1::den / __gcd_d1_n2)>::type;
};

template <class _R1, class _R2>
using ratio_multiply = typename __ratio_multiply<_R1, _R2>::type;

template <class _R1, class _R2>
struct __ratio_divide
{
  // private:
  static const intmax_t __gcd_n1_n2 = _CUDA_VSTD::__static_gcd(_R1::num, _R2::num);
  static const intmax_t __gcd_d1_d2 = _CUDA_VSTD::__static_gcd(_R1::den, _R2::den);

public:
  using type = typename ratio<_CUDA_VSTD::__ll_mul(_R1::num / __gcd_n1_n2, _R2::den / __gcd_d1_d2),
                              _CUDA_VSTD::__ll_mul(_R2::num / __gcd_n1_n2, _R1::den / __gcd_d1_d2)>::type;
};

template <class _R1, class _R2>
using ratio_divide = typename __ratio_divide<_R1, _R2>::type;

template <class _R1, class _R2>
struct __ratio_add
{
  // private:
  static const intmax_t __gcd_n1_n2 = _CUDA_VSTD::__static_gcd(_R1::num, _R2::num);
  static const intmax_t __gcd_d1_d2 = _CUDA_VSTD::__static_gcd(_R1::den, _R2::den);

public:
  using type = typename ratio_multiply<
    ratio<__gcd_n1_n2, _R1::den / __gcd_d1_d2>,
    ratio<_CUDA_VSTD::__ll_add(_CUDA_VSTD::__ll_mul(_R1::num / __gcd_n1_n2, _R2::den / __gcd_d1_d2),
                               _CUDA_VSTD::__ll_mul(_R2::num / __gcd_n1_n2, _R1::den / __gcd_d1_d2)),
          _R2::den>>::type;
};

template <class _R1, class _R2>
using ratio_add = typename __ratio_add<_R1, _R2>::type;

template <class _R1, class _R2>
struct __ratio_subtract
{
  // private:
  static const intmax_t __gcd_n1_n2 = _CUDA_VSTD::__static_gcd(_R1::num, _R2::num);
  static const intmax_t __gcd_d1_d2 = _CUDA_VSTD::__static_gcd(_R1::den, _R2::den);

public:
  using type = typename ratio_multiply<
    ratio<__gcd_n1_n2, _R1::den / __gcd_d1_d2>,
    ratio<_CUDA_VSTD::__ll_sub(_CUDA_VSTD::__ll_mul(_R1::num / __gcd_n1_n2, _R2::den / __gcd_d1_d2),
                               _CUDA_VSTD::__ll_mul(_R2::num / __gcd_n1_n2, _R1::den / __gcd_d1_d2)),
          _R2::den>>::type;
};

template <class _R1, class _R2>
using ratio_subtract = typename __ratio_subtract<_R1, _R2>::type;

// ratio_equal

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_equal : public bool_constant<(_R1::num == _R2::num && _R1::den == _R2::den)>
{};

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_not_equal : public bool_constant<(!ratio_equal<_R1, _R2>::value)>
{};

// ratio_less

template <class _R1,
          class _R2,
          bool _Odd    = false,
          intmax_t _Q1 = _R1::num / _R1::den,
          intmax_t _M1 = _R1::num % _R1::den,
          intmax_t _Q2 = _R2::num / _R2::den,
          intmax_t _M2 = _R2::num % _R2::den>
struct __ratio_less1
{
  static const bool value = _Odd ? _Q2 < _Q1 : _Q1 < _Q2;
};

template <class _R1, class _R2, bool _Odd, intmax_t _Qp>
struct __ratio_less1<_R1, _R2, _Odd, _Qp, 0, _Qp, 0>
{
  static const bool value = false;
};

template <class _R1, class _R2, bool _Odd, intmax_t _Qp, intmax_t _M2>
struct __ratio_less1<_R1, _R2, _Odd, _Qp, 0, _Qp, _M2>
{
  static const bool value = !_Odd;
};

template <class _R1, class _R2, bool _Odd, intmax_t _Qp, intmax_t _M1>
struct __ratio_less1<_R1, _R2, _Odd, _Qp, _M1, _Qp, 0>
{
  static const bool value = _Odd;
};

template <class _R1, class _R2, bool _Odd, intmax_t _Qp, intmax_t _M1, intmax_t _M2>
struct __ratio_less1<_R1, _R2, _Odd, _Qp, _M1, _Qp, _M2>
{
  static const bool value = __ratio_less1<ratio<_R1::den, _M1>, ratio<_R2::den, _M2>, !_Odd>::value;
};

template <class _R1,
          class _R2,
          intmax_t _S1 = _CUDA_VSTD::__ratio_sign(_R1::num),
          intmax_t _S2 = _CUDA_VSTD::__ratio_sign(_R2::num)>
struct __ratio_less
{
  static const bool value = _S1 < _S2;
};

template <class _R1, class _R2>
struct __ratio_less<_R1, _R2, 1LL, 1LL>
{
  static const bool value = __ratio_less1<_R1, _R2>::value;
};

template <class _R1, class _R2>
struct __ratio_less<_R1, _R2, -1LL, -1LL>
{
  static const bool value = __ratio_less1<ratio<-_R2::num, _R2::den>, ratio<-_R1::num, _R1::den>>::value;
};

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_less : public bool_constant<(__ratio_less<_R1, _R2>::value)>
{};

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_less_equal : public bool_constant<(!ratio_less<_R2, _R1>::value)>
{};

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_greater : public bool_constant<(ratio_less<_R2, _R1>::value)>
{};

template <class _R1, class _R2>
struct _CCCL_TYPE_VISIBILITY_DEFAULT ratio_greater_equal : public bool_constant<(!ratio_less<_R1, _R2>::value)>
{};

template <class _R1, class _R2>
struct __ratio_gcd
{
  using type = ratio<_CUDA_VSTD::__static_gcd(_R1::num, _R2::num), _CUDA_VSTD::__static_lcm(_R1::den, _R2::den)>;
};

template <class _R1, class _R2>
inline constexpr bool ratio_equal_v = ratio_equal<_R1, _R2>::value;

template <class _R1, class _R2>
inline constexpr bool ratio_not_equal_v = ratio_not_equal<_R1, _R2>::value;

template <class _R1, class _R2>
inline constexpr bool ratio_less_v = ratio_less<_R1, _R2>::value;

template <class _R1, class _R2>
inline constexpr bool ratio_less_equal_v = ratio_less_equal<_R1, _R2>::value;

template <class _R1, class _R2>
inline constexpr bool ratio_greater_v = ratio_greater<_R1, _R2>::value;

template <class _R1, class _R2>
inline constexpr bool ratio_greater_equal_v = ratio_greater_equal<_R1, _R2>::value;

